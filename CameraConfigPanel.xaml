<UserControl x:Class="SuperWorkspace.CameraConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#CC000000">
    <Border Background="#252526" Width="400" Height="520" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
        <StackPanel>
            <TextBlock Text="🎥 超级虚拟相机" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            
            <TextBlock Text="产品经理的智慧：让手机做它最擅长的事！" Foreground="#A074E5" FontSize="15" FontWeight="Bold" Margin="0,0,0,15" TextWrapping="Wrap"/>
            <TextBlock Text="本模式将直接捕获您手机的「屏幕画面」，然后注入到电脑的虚拟摄像头中。" Foreground="#AAAAAA" FontSize="14" Margin="0,0,0,10" TextWrapping="Wrap"/>
            <TextBlock Text="👉 请在启动后，手动打开手机上的「原生相机 App」或「任何带美颜滤镜的 App」，即可将其画面无损推送到电脑！" Foreground="#00BFFF" FontSize="14" FontWeight="Bold" Margin="0,0,0,20" TextWrapping="Wrap"/>
            <TextBlock Text="⚠️ 注意：电脑端不会采集手机麦克风，请使用电脑自带或外接麦克风！" Foreground="#D83B01" FontSize="12" Margin="0,0,0,20" TextWrapping="Wrap"/>

            <Rectangle Height="1" Fill="#333" Margin="0,0,0,15"/>
            <Button Content="🔧 一键修复/安装 SuperWorkspace Camera 驱动" Background="#333" Foreground="#A074E5" FontWeight="Bold" Height="30" FontSize="13" Cursor="Hand" BorderThickness="0" Margin="0,0,0,30" Click="Btn_InstallDriver_Click"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="取 消" Background="#444444" Foreground="White" Height="40" FontSize="16" Cursor="Hand" BorderThickness="0" Click="Btn_CancelCameraConfig_Click"/>
                <Button Grid.Column="2" Content="🚀 立即开启虚拟相机流" Background="#A074E5" Foreground="White" Height="40" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Style="{DynamicResource PrimaryCyberButtonStyle}" Click="Btn_LaunchCamera_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>