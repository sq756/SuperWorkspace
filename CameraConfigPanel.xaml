<UserControl x:Class="SuperWorkspace.CameraConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#CC000000">
    <Border Background="#252526" Width="400" Height="520" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
        <StackPanel>
            <TextBlock Text="🎥 超级视听采集配置" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            
            <TextBlock Text="视频输入源 (完全保护隐私，手机端无画面)" Foreground="#AAAAAA" FontSize="14" Margin="0,0,0,5"/>
            <ComboBox x:Name="ComboCameraSource" SelectedIndex="0" FontSize="14" Height="30" Margin="0,0,0,20">
                <ComboBoxItem Content="📱 手机前置摄像头 (适合开会)"/>
                <ComboBoxItem Content="📷 手机后置主摄 (画质最强)"/>
                <ComboBoxItem Content="🎤 纯麦克风 / KTV 模式 (无延迟拔麦)"/>
            </ComboBox>

            <Rectangle Height="1" Fill="#333" Margin="0,0,0,15"/>
            <TextBlock Text="采集画质" Foreground="#AAAAAA" FontSize="14" Margin="0,0,0,5"/>
            <ComboBox x:Name="ComboCameraRes" SelectedIndex="1" FontSize="14" Height="30" Margin="0,0,0,20">
                <ComboBoxItem Content="720P (流畅开会)"/>
                <ComboBoxItem Content="1080P (高清录制)"/>
            </ComboBox>

            <Rectangle Height="1" Fill="#333" Margin="0,0,0,15"/>
            <TextBlock Text="声音与高级选项" Foreground="#AAAAAA" FontSize="14" Margin="0,0,0,10"/>
            <CheckBox x:Name="CheckEnableMic" Content="采集手机麦克风 (作为电脑无损输入)" IsChecked="True" Foreground="White" FontSize="14" Margin="0,0,0,15"/>
            <CheckBox x:Name="CheckCameraScreenOff" Content="启动时手机自动息屏 (荣耀机型慎选)" IsChecked="False" Foreground="White" FontSize="14" Margin="0,0,0,15"/>

            <Button Content="🔧 一键修复/安装系统虚拟摄像头驱动" Background="#333" Foreground="#A074E5" FontWeight="Bold" Height="30" FontSize="13" Cursor="Hand" BorderThickness="0" Margin="0,0,0,20" Click="Btn_InstallDriver_Click"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="取 消" Background="#444444" Foreground="White" Height="40" FontSize="16" Cursor="Hand" BorderThickness="0" Click="Btn_CancelCameraConfig_Click"/>
                <Button Grid.Column="2" Content="🚀 立即开启虚拟相机流" Background="#A074E5" Foreground="White" Height="40" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Style="{DynamicResource PrimaryCyberButtonStyle}" Click="Btn_LaunchCamera_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>