<Window x:Class="SuperWorkspace.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Super Workspace - 终端" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI"
        WindowStyle="None" AllowsTransparency="True" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- 🌟 全局深色渐变背景：告别死黑，带来呼吸感 -->
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0D0D12" Offset="0"/>
            <GradientStop Color="#1A1A24" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    
    <Window.Resources>
        <!-- 🌟 核心卡片视觉语言：半透明、霓虹投影、线性交互 -->
        <Style TargetType="Button" x:Key="FunctionCardStyle">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Width" Value="210"/>
            <Setter Property="Height" Value="130"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform"><Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="12" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}" Padding="15">
                            <Grid>
                                <!-- 🌟 状态反馈：后台运行时的绿色呼吸灯 -->
                                <Ellipse x:Name="ActiveIndicator" Width="8" Height="8" Fill="#00CA72" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-5,-5,0,0" Visibility="Collapsed">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#00CA72" BlurRadius="8" ShadowDepth="0"/>
                                    </Ellipse.Effect>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:1" AutoReverse="True" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <ContentPresenter x:Name="ContentSite" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ContentPresenter.RenderTransform>
                                        <TranslateTransform Y="0"/>
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#A074E5"/>
                                <Setter Property="Background" Value="#25FFFFFF"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="20" Color="#A074E5" Opacity="0.6" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.15"/>
                                            <!-- 🌟 微动效：内部图标产生轻微的 3D 悬浮上移偏移 (Tilt Effect) -->
                                            <DoubleAnimation Storyboard.TargetName="ContentSite" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="-4" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="ContentSite" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#35FFFFFF"/>
                            </Trigger>
                            <!-- 🌟 状态反馈：后台运行时背景产生淡淡的流光 -->
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible"/>
                                <Setter Property="BorderBrush" Value="#6600CA72"/>
                                <Setter Property="Background" Value="#1500CA72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🌟 全局动作按钮样式：无虚线框、圆角统一、柔和的交互渐变 -->
        <Style TargetType="Button" x:Key="CyberActionButtonStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/> <!-- 彻底消灭廉价的焦点虚线框 -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                <Trigger Property="IsPressed" Value="True"><Setter Property="Opacity" Value="0.6"/></Trigger>
            </Style.Triggers>
        </Style>

        <!-- 🌟 发光主行动按钮 (Primary Action Glow) -->
        <Style TargetType="Button" x:Key="PrimaryCyberButtonStyle" BasedOn="{StaticResource CyberActionButtonStyle}">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#A074E5" BlurRadius="12" Opacity="0.5" ShadowDepth="0"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🌟 滑块辅助：隐藏加号减号按钮 -->
        <Style x:Key="SliderRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="SliderActiveTrackStyle" TargetType="RepeatButton">
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RepeatButton">
                <Border Background="#A074E5" CornerRadius="3" Margin="0,-3,0,-3">
                    <Border.Effect><DropShadowEffect Color="#A074E5" BlurRadius="8" Opacity="0.6" ShadowDepth="0"/></Border.Effect>
                </Border>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <!-- 🌟 极简毛玻璃滚动条样式 (固定 6px 幽灵光带版) -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <!-- 🌟 核心修复：把透明度转移到模板内部的根节点 Grid 上，彻底保护外部视觉树 -->
                        <Grid x:Name="Bg" Background="Transparent" Opacity="0.1">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <!-- 🌟 核心修复：必须保留被隐藏的 RepeatButton！否则 WPF 引擎会判定模板无效，并强行退回系统粗糙滚动条！ -->
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButtonStyle}" Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButtonStyle}" Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder" CornerRadius="3" Background="#A074E5" Margin="0"/>
                                                <ControlTemplate.Triggers>
                                                    <!-- 🌟 交互反馈：鼠标悬停增加发光 -->
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect BlurRadius="10" Color="#A074E5" Opacity="0.8" ShadowDepth="0"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="Height" Value="6"/>
                                <Setter Property="MinHeight" Value="6"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🌟 赛博朋克风下拉框组件样式 -->
        <Style TargetType="ComboBox" x:Key="CyberComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33A074E5"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#8A2BE2"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            <ToggleButton Name="ToggleButton" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border CornerRadius="8" Background="Transparent">
                                            <Path x:Name="Arrow" Fill="#AAAAAA" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" Data="M0,0 L4,4 L8,0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="15,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <!-- 🌟 核心修复：移除水平偏移纠偏，移除多余内边距，并强制使弹出层与主体宽度进行像素级咬合 (Width="{TemplateBinding ActualWidth}") -->
                            <Popup Name="Popup" Placement="Bottom" HorizontalOffset="0" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Name="DropDownBorder" Background="#1A1A24" BorderThickness="1" BorderBrush="#A074E5" CornerRadius="8" Margin="0,4,0,20" MaxHeight="{TemplateBinding MaxDropDownHeight}" MinWidth="{TemplateBinding ActualWidth}" Width="{TemplateBinding ActualWidth}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" Color="#A074E5" Opacity="0.4" ShadowDepth="0"/>
                                    </Border.Effect>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🌟 赛博朋克风全息滑块 -->
        <Style TargetType="Slider">
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="6" Background="#33FFFFFF" CornerRadius="3" VerticalAlignment="Center" Margin="8,0"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderActiveTrackStyle}" Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderRepeatButtonStyle}" Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid Background="Transparent">
                                                    <Ellipse x:Name="Glow" Width="22" Height="22" Fill="#A074E5" Opacity="0">
                                                        <Ellipse.Effect><BlurEffect Radius="8"/></Ellipse.Effect>
                                                    </Ellipse>
                                                    <Ellipse x:Name="ThumbEl" Width="16" Height="16" Fill="White" Stroke="#A074E5" StrokeThickness="2"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="Glow" Property="Opacity" Value="0.8"/>
                                                        <Setter TargetName="ThumbEl" Property="Fill" Value="#A074E5"/>
                                                        <Setter TargetName="ThumbEl" Property="Width" Value="18"/>
                                                        <Setter TargetName="ThumbEl" Property="Height" Value="18"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Glow" Property="Opacity" Value="0.4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🌟 赛博托盘菜单样式 -->
        <Style x:Key="CyberTrayMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#1E1E24" CornerRadius="8" BorderBrush="#3F3F46" BorderThickness="1" Margin="15">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.8" ShadowDepth="0"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🌟 赛博托盘菜单项样式 -->
        <Style x:Key="CyberMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Margin="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter ContentSource="Icon" Margin="10,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                <TextBlock Grid.Column="2" x:Name="CheckMark" Text="✔" Foreground="#00CA72" VerticalAlignment="Center" Visibility="Hidden" FontFamily="Segoe UI" FontWeight="Bold"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33A074E5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 🌟 托盘菜单实例 -->
        <ContextMenu x:Key="TrayMenu" Style="{StaticResource CyberTrayMenuStyle}">
            <MenuItem Header="显示控制台" Click="TrayMenu_Show_Click" Style="{StaticResource CyberMenuItemStyle}">
                <MenuItem.Icon>
                    <Path Data="M2,4 H22 V16 H2 Z M10,16 V20 H14 V16" Stroke="#A074E5" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem x:Name="TrayMenu_AutoStart" Header="开机静默自启" IsCheckable="True" Click="TrayMenu_AutoStart_Click" Style="{StaticResource CyberMenuItemStyle}">
                <MenuItem.Icon>
                    <Path Data="M12,2 L15,8 L20,10 L15,12 L12,20 L9,12 L2,10 L9,8 Z" Fill="#00BFFF" Stretch="Uniform" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator Background="#333" Margin="10,5"/>
            <MenuItem Header="彻底退出并断开设备" Click="TrayMenu_Exit_Click" Style="{StaticResource CyberMenuItemStyle}">
                <MenuItem.Icon>
                    <Path Data="M12,2 V10 M6,6 A10,10 0 1,0 18,6" Stroke="#D83B01" StrokeThickness="1.5" Fill="Transparent" Stretch="Uniform" Width="14" Height="14"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <!-- 🌟 极简幽灵滑块 (Ghost Slider) - 随叫随到，不叫不到 -->
        <Style TargetType="Slider" x:Key="GhostSliderStyle">
            <Setter Property="MinHeight" Value="14"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent">
                            <Border x:Name="TrackBg" Height="2" Background="#15FFFFFF" CornerRadius="1" VerticalAlignment="Center" Margin="5,0"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="2" Background="#A074E5" CornerRadius="1" Margin="5,0,-5,0"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="ThumbEl" Width="0" Height="0" Fill="White" Stroke="#A074E5" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Ellipse.Effect><DropShadowEffect Color="#A074E5" BlurRadius="8" ShadowDepth="0" Opacity="0"/></Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <!-- 鼠标悬停在整个滑块上时，Thumb 瞬间放大浮现 -->
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type Slider}}}" Value="True">
                                                        <Setter TargetName="ThumbEl" Property="Width" Value="14"/>
                                                        <Setter TargetName="ThumbEl" Property="Height" Value="14"/>
                                                        <Setter TargetName="ThumbEl" Property="Effect">
                                                            <Setter.Value><DropShadowEffect Color="#A074E5" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/></Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbEl" Property="Width" Value="16"/>
                                                        <Setter TargetName="ThumbEl" Property="Height" Value="16"/>
                                                        <Setter TargetName="ThumbEl" Property="Fill" Value="#A074E5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TrackBg" Property="Height" Value="4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/> <RowDefinition Height="*"/> </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
            <TextBlock Text="PC Workspace" Foreground="White" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text=" | 电脑扩展坞" Foreground="#888888" FontSize="18" VerticalAlignment="Bottom" Margin="10,0,0,5"/>
        </StackPanel>
        
        <StackPanel Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Margin="0,0,20,0">
            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Btn_Minimize_Click" ToolTip="最小化" Margin="0,0,15,0">
                <TextBlock Text="➖" FontSize="20" Foreground="#888">
                    <TextBlock.Style><Style TargetType="TextBlock"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Foreground" Value="White"/></Trigger></Style.Triggers></Style></TextBlock.Style>
                </TextBlock>
            </Button>
            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Btn_Maximize_Click" ToolTip="最大化/还原" Margin="0,0,15,0">
                <TextBlock x:Name="TxtBtnMaximize" Text="🔲" FontSize="18" Foreground="#888" VerticalAlignment="Center">
                    <TextBlock.Style><Style TargetType="TextBlock"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Foreground" Value="White"/></Trigger></Style.Triggers></Style></TextBlock.Style>
                </TextBlock>
            </Button>
            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Btn_Close_Click" ToolTip="关闭" Margin="0,0,15,0">
                <TextBlock Text="❌" FontSize="20" Foreground="#888">
                    <TextBlock.Style><Style TargetType="TextBlock"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Foreground" Value="#D83B01"/></Trigger></Style.Triggers></Style></TextBlock.Style>
                </TextBlock>
            </Button>
            <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Btn_About_Click" ToolTip="关于与设置">
                <TextBlock Text="⚙️" FontSize="20" Foreground="#888">
                    <TextBlock.Style><Style TargetType="TextBlock"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Foreground" Value="#00BFFF"/></Trigger></Style.Triggers></Style></TextBlock.Style>
                </TextBlock>
            </Button>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>     <ColumnDefinition Width="320"/>   </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="MainFunctionPanel" Margin="20" Orientation="Horizontal">
                    <!-- 📱 手机接管系 -->
                    <Button x:Name="Card_PcReceiver" Style="{StaticResource FunctionCardStyle}" Click="Btn_PcReceiver_Click">
                        <StackPanel>
                            <TextBlock Text="📱" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="手机镜像" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center"/>
                            <TextBlock Text="PC Receiver" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
