                            <TextBlock Text="扩展电脑副屏" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center"/>
                            <TextBlock Text="Display Ext." Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
