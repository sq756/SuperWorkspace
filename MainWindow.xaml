                    </Button>

                    <!-- 🎮 虚拟外设系 -->
                    <Button x:Name="Card_Trackpad" Style="{StaticResource FunctionCardStyle}" Click="Btn_VirtualInput_Click">
                        <StackPanel>
                            <TextBlock Text="🪄" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="触摸板模式" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center"/>
                            <TextBlock Text="Magic Trackpad" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="Card_StreamDeck" Style="{StaticResource FunctionCardStyle}" Click="Btn_StreamDeck_Click">
                        <StackPanel>
                            <TextBlock Text="🎛️" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Stream Deck" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Macro Pad" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="Card_Tablet" Style="{StaticResource FunctionCardStyle}" Click="Btn_GraphicsTablet_Click">
                        <StackPanel>
                            <TextBlock Text="🎨" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="数位板映射" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center"/>
                            <TextBlock Text="Graphics Tablet" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- 🎥 影音路由系 -->
                    <Button x:Name="Card_Camera" Style="{StaticResource FunctionCardStyle}" Click="Btn_Camera_Click">
                        <StackPanel>
                            <TextBlock Text="🎥" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="虚拟摄像头" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center"/>
                            <TextBlock Text="Virtual Camera" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="Card_Audio" Style="{StaticResource FunctionCardStyle}" Click="Btn_AudioRouting_Click">
                        <StackPanel>
                            <TextBlock Text="🎤" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="音频路由" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center"/>
                            <TextBlock Text="Audio Routing" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="Card_Audio2" Style="{StaticResource FunctionCardStyle}" Click="Btn_AudioRouting2_Click">
                        <StackPanel>
                            <TextBlock Text="🎧" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="极速音频 (MVP)" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center"/>
                            <TextBlock Text="Opus Stream" Foreground="#00CA72" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="Card_ZeroSync" Style="{StaticResource FunctionCardStyle}" Click="Btn_ZeroSync_Click">
                        <StackPanel>
                            <TextBlock Text="🌌" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="无缝同步" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center"/>
                            <TextBlock Text="Zero-Sync" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource FunctionCardStyle}" Background="#05FFFFFF" BorderThickness="2" Click="Btn_PluginMarket_Click">
                        <StackPanel>
                            <TextBlock Text="➕" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10" Opacity="0.5"/>
                            <TextBlock Text="探索更多生态" FontWeight="Bold" FontSize="16" Foreground="#888" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Background="#15FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" Margin="0,20,20,20" CornerRadius="12" Padding="5,20,5,20">
                <!-- 🌟 将右侧监控区包裹进滚动视图中 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15,0,15,0">
                    <StackPanel>
                    <TextBlock Text="📊 实时监控 (Beta)" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                    <Rectangle Height="1" Fill="#444" Margin="0,0,0,15"/>


                    <TextBlock Text="📱 设备管理中枢" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,10,0,10"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <ComboBox x:Name="ComboDeviceList" Width="200" Height="35" Margin="0,0,10,0" FontSize="13"
                                  Style="{StaticResource CyberComboBox}" DisplayMemberPath="Model" SelectionChanged="ComboDeviceList_SelectionChanged"/>
                        
                        <Button x:Name="Btn_RefreshDevices" Content="🔄" Width="35" Height="35" Background="#25FFFFFF" 
                                Style="{StaticResource CyberActionButtonStyle}" Click="Btn_RefreshDevices_Click"/>
                        
                    </StackPanel>

                    <!-- 🌟 网络连接双擎：有线转无线 & 免线直连 -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="Btn_MakeWireless" Grid.Column="0" Content="🪄 有线转无线" Background="#A074E5" Height="35" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_MakeWireless_Click" ToolTip="已插USB时，一键切换至 Wi-Fi 模式"/>
                        <Button x:Name="Btn_ZeroCablePairing" Grid.Column="2" Content="📶 免线隔空连" Background="#00BFFF" Foreground="Black" FontWeight="Bold" Height="35" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_ZeroCablePairing_Click" ToolTip="Android 11+ 无需插线，使用配对码直接连接"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#33FFFFFF" Margin="0,0,0,15"/>

                    <TextBlock Text="连接状态" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <!-- 🌟 呼吸灯指示器 -->
                        <Ellipse x:Name="Indicator_Connection" Width="8" Height="8" Fill="#D83B01" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.2" To="1.0" Duration="0:0:1" AutoReverse="True" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock x:Name="Monitor_Connection" Text="离线 / 未知协议" Foreground="#A074E5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- 🔋 电量磁贴卡片 -->
                        <Border Grid.Column="0" Background="#15FFFFFF" CornerRadius="8" Padding="12" BorderBrush="#22FFFFFF" BorderThickness="1" MouseLeftButtonDown="Border_Battery_MouseLeftButtonDown" Cursor="Hand" ToolTip="双击查看详细分析 | 右键切换传感器">
                            <Border.ContextMenu>
                                <ContextMenu Style="{StaticResource CyberTrayMenuStyle}">
                                    <MenuItem Header="🔋 监控电量百分比 (默认)" Click="Menu_BatteryLevel_Click" Style="{StaticResource CyberMenuItemStyle}"/>
                                    <MenuItem Header="⚡ 监控电池电压 (V)" Click="Menu_BatteryVoltage_Click" Style="{StaticResource CyberMenuItemStyle}"/>
                                    <MenuItem Header="🌊 监控实时电流 (mA)" Click="Menu_BatteryCurrent_Click" Style="{StaticResource CyberMenuItemStyle}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="Indicator_BatteryState" Width="4" Height="4" Fill="#555555" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.2" To="0.5" Duration="0:0:2" AutoReverse="True" RepeatBehavior="Forever"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                        <TextBlock x:Name="Monitor_BatteryLabel" Text="🔋 电量百分比" Foreground="#00CA72" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="Monitor_Battery" Text="DORMANT" Foreground="#444444" FontSize="18" FontWeight="Bold">
                                        <TextBlock.Effect>
                                            <BlurEffect Radius="2" KernelType="Gaussian"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock x:Name="Monitor_BatteryUnit" Text="" Foreground="#888" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                                    <TextBlock x:Name="Monitor_IsCharging" Text="" Foreground="#A074E5" FontSize="14" VerticalAlignment="Bottom" Margin="4,0,0,2"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- 🌡️ 温度磁贴卡片 -->
                        <Border x:Name="Border_Temp" Grid.Column="2" Background="#15FFFFFF" CornerRadius="8" Padding="12" BorderBrush="#22FFFFFF" BorderThickness="1" MouseLeftButtonDown="Border_Temp_MouseLeftButtonDown" Cursor="Hand" ToolTip="双击查看温度分析 | 右键切换传感器">
                            <Border.ContextMenu>
                                <ContextMenu Style="{StaticResource CyberTrayMenuStyle}">
                                    <MenuItem Header="🔋 监控电池温度 (默认)" Click="Menu_TempBattery_Click" Style="{StaticResource CyberMenuItemStyle}"/>
                                    <MenuItem Header="🧠 监控 CPU 核心温度" Click="Menu_TempCpu_Click" Style="{StaticResource CyberMenuItemStyle}"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="Indicator_TempState" Width="4" Height="4" Fill="#555555" Margin="0,0,6,0" VerticalAlignment="Center">
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.2" To="0.5" Duration="0:0:2" AutoReverse="True" RepeatBehavior="Forever"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                        <TextBlock x:Name="Monitor_TempLabel" Text="🔋 电池温度" Foreground="#00CA72" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="Monitor_Temp" Text="DORMANT" Foreground="#444444" FontSize="18" FontWeight="Bold">
                                        <TextBlock.Effect>
                                            <BlurEffect Radius="2" KernelType="Gaussian"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock x:Name="Monitor_TempUnit" Text="" Foreground="#888" FontSize="12" VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Rectangle Height="1" Fill="#33FFFFFF" Margin="0,0,0,20"/>

                    <TextBlock Text="视频流性能" Foreground="#888" FontSize="12" Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="帧率" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                        <!-- 🌟 波形图王者归来：使用 Viewbox Stretch="Fill" 彻底解决溢出问题 -->
                        <Border Grid.Column="1" Margin="10,0" Height="20" Background="#0AFFFFFF" CornerRadius="4" MouseLeftButtonDown="Border_FPS_MouseLeftButtonDown" Cursor="Hand" ToolTip="双击查看帧率分析">
                            <Viewbox Stretch="Fill" ClipToBounds="True">
                                <Canvas Width="200" Height="20">
                                    <Polygon x:Name="Polygon_FPS" Fill="#33A074E5" Stroke="#A074E5" StrokeThickness="1.5" Points="0,20 200,20"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock x:Name="Monitor_FPS" Grid.Column="2" Text="-- fps" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="带宽" Foreground="#888" FontSize="12"/>
                            <TextBlock x:Name="Monitor_Protocol" Text="USB" Foreground="#00CA72" FontSize="9" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" Margin="10,0" Height="20" Background="#0AFFFFFF" CornerRadius="4" MouseLeftButtonDown="Border_Bitrate_MouseLeftButtonDown" Cursor="Hand" ToolTip="双击查看带宽分析">
                            <Viewbox Stretch="Fill" ClipToBounds="True">
                                <Canvas Width="200" Height="20">
                                    <Polygon x:Name="Polygon_Bitrate" Fill="#3300CA72" Stroke="#00CA72" StrokeThickness="1.5" Points="0,20 200,20"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock x:Name="Monitor_Bitrate" Grid.Column="2" Text="-- Mbps" Foreground="White" TextAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <Button x:Name="Btn_ToggleBatteryGuard" Content="🛡️ 智能旁路保护: 已关闭" Background="#15FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" Height="35" Margin="0,10,0,0" 
                            Style="{StaticResource CyberActionButtonStyle}" Click="Btn_ToggleBatteryGuard_Click"/>
                    
                    <Button x:Name="Btn_ToggleMonitor" Content="▶ 启动硬件雷达" Background="#333333" Height="35" Margin="0,20,0,0" 
                            Style="{StaticResource CyberActionButtonStyle}" Click="Btn_ToggleMonitor_Click"/>

                    <!-- 🌟 链路雷达深度折叠区 (Link Radar Folding Area) -->
                    <Grid Margin="0,20,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ToggleButton x:Name="RadarToggle" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalContentAlignment="Stretch">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="#1A1A24" CornerRadius="8" Padding="10" BorderBrush="#33FFFFFF" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- 🌟 旋转雷达动画 -->
                                            <TextBlock Grid.Column="0" Text="📡" Foreground="#A074E5" FontSize="14" RenderTransformOrigin="0.5,0.5">
                                                <TextBlock.RenderTransform><RotateTransform Angle="0"/></TextBlock.RenderTransform>
                                                <TextBlock.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard><DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:2" RepeatBehavior="Forever"/></Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </TextBlock.Triggers>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Text=" 链路雷达深度检测 (Link Radar)" Foreground="#E0E0E0" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                            <Path Grid.Column="2" Data="M0,0 L5,5 L10,0" Stroke="#888" StrokeThickness="2" VerticalAlignment="Center" HorizontalAlignment="Right" RenderTransformOrigin="0.5,0.5">
                                                <Path.Style>
                                                    <Style TargetType="Path">
                                                        <Style.Triggers>
                                                            <!-- 展开时箭头旋转 -->
                                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                                <Setter Property="RenderTransform"><Setter.Value><RotateTransform Angle="180"/></Setter.Value></Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Path.Style>
                                            </Path>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        
                        <Border Grid.Row="1" Background="#0A0A0F" CornerRadius="8" Margin="0,5,0,0" Padding="15" BorderBrush="#22FFFFFF" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=RadarToggle}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            
                            <StackPanel>
                                <!-- 1. 链路体检 -->
                                <TextBlock x:Name="Radar_LinkTitle" Text="Wired 物理链路体检" Foreground="#AAA" FontSize="11" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="协商速率" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Radar_LinkSpeed" Text="--Mbps" Foreground="#00CA72" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="错误帧 (CRC)" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Radar_CRC" Text="0" Foreground="#00CA72" FontSize="12" FontFamily="Consolas" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="丢包率 (Loss)" Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <!-- 极小红色直方图，0%时不显示宽度 -->
                                        <Grid Width="40" Height="4" Background="#222" Margin="0,0,6,0" ClipToBounds="True">
                                            <Rectangle x:Name="Radar_LossBar" Width="0" Fill="#D83B01" HorizontalAlignment="Left"/>
                                        </Grid>
                                        <TextBlock x:Name="Radar_LossText" Text="0%" Foreground="#00CA72" FontSize="12" FontFamily="Consolas" Width="20" TextAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                                
                                <Rectangle Height="1" Fill="#222" Margin="0,0,0,12"/>
                                
                                <!-- 2. IO 延时 Breakdown -->
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="IO 延时探针 (Breakdown)" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Radar_LatTotal" Text="Total: --ms" Foreground="#A074E5" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Height="6" Margin="0,0,0,6" ClipToBounds="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="Radar_ColLatTouch" Width="1*"/>
                                        <ColumnDefinition x:Name="Radar_ColLatEncode" Width="2*"/>
                                        <ColumnDefinition x:Name="Radar_ColLatNet" Width="1*"/>
                                        <ColumnDefinition x:Name="Radar_ColLatDecode" Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Column="0" Fill="#00BFFF" ToolTip="触控: 1ms" Margin="0,0,1,0" RadiusX="3" RadiusY="3"/>
                                    <Rectangle Grid.Column="1" Fill="#A074E5" ToolTip="编码: 2ms" Margin="0,0,1,0" RadiusX="3" RadiusY="3"/>
                                    <Rectangle Grid.Column="2" Fill="#00CA72" ToolTip="网络: 1ms" Margin="0,0,1,0" RadiusX="3" RadiusY="3"/>
                                    <Rectangle Grid.Column="3" Fill="#D83B01" ToolTip="解码: 1ms" RadiusX="3" RadiusY="3"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock x:Name="Radar_TxtLatTouch" Grid.Column="0" Text="触 --ms" Foreground="#00BFFF" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="Radar_TxtLatEncode" Grid.Column="1" Text="编 --ms" Foreground="#A074E5" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="Radar_TxtLatNet" Grid.Column="2" Text="网 --ms" Foreground="#00CA72" FontSize="9" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="Radar_TxtLatDecode" Grid.Column="3" Text="解 --ms" Foreground="#D83B01" FontSize="9" HorizontalAlignment="Center"/>
                                </Grid>

                                <Rectangle Height="1" Fill="#222" Margin="0,0,0,12"/>

                                <!-- 3. 多设备能效矩阵 & QoS -->
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="能效矩阵与流量抢占 (QoS)" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="Radar_PowerTotal" Text="Total: --W" Foreground="#888" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#111" CornerRadius="6" Padding="8,6" Margin="0,0,4,0" BorderBrush="#333" BorderThickness="1">
                                        <Grid>
