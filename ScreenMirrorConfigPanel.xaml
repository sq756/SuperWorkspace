<UserControl x:Class="SuperWorkspace.ScreenMirrorConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#CC000000">
    <Border Background="#252526" Width="400" Height="660" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
        <StackPanel>
            <TextBlock Text="⚙️ 投屏参数配置" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            
            <TextBlock Text="画质与分辨率" Foreground="#AAAAAA" FontSize="14" Margin="0,0,0,5"/>
            <ComboBox x:Name="ComboResolution" SelectedIndex="0" FontSize="14" Height="30" Margin="0,0,0,20">
                <ComboBoxItem Content="流畅 1080P (兼容性极佳)"/>
                <ComboBoxItem Content="高清 2K (需要 Type-C 3.0线缆)"/>
                <ComboBoxItem Content="满血原生分辨率 (极其吃性能)"/>
            </ComboBox>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="最高帧率 (FPS): " Foreground="#AAAAAA" FontSize="14"/>
                <TextBlock x:Name="TextFpsValue" Text="{Binding ElementName=SliderFps, Path=Value}" Foreground="#A074E5" FontSize="14" FontWeight="Bold"/>
            </StackPanel>
            <Slider x:Name="SliderFps" Minimum="30" Maximum="120" Value="60" TickFrequency="30" IsSnapToTickEnabled="True" Margin="0,0,0,25"/>

            <Rectangle Height="1" Fill="#333" Margin="0,0,0,20"/>
            <TextBlock Text="视频编码与传输码率" Foreground="#AAAAAA" FontSize="14" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <ComboBox x:Name="ComboCodec" SelectedIndex="0" FontSize="14" Height="30" Width="150" Margin="0,0,10,0">
                    <ComboBoxItem Content="自动协商编码"/>
                    <ComboBoxItem Content="强制 H.264"/>
                    <ComboBoxItem Content="强制 H.265"/>
                </ComboBox>
                <ComboBox x:Name="ComboBitrate" SelectedIndex="1" FontSize="14" Height="30" Width="120">
                    <ComboBoxItem Content="8 Mbps"/>
                    <ComboBoxItem Content="20 Mbps"/>
                    <ComboBoxItem Content="50 Mbps"/>
                </ComboBox>
            </StackPanel>

            <Rectangle Height="1" Fill="#333" Margin="0,0,0,20"/>
            <TextBlock Text="键盘控制模式 (解决中文与软键盘占用)" Foreground="#AAAAAA" FontSize="14" Margin="0,0,0,5"/>
            <ComboBox x:Name="ComboKeyboard" SelectedIndex="2" FontSize="14" Height="30" Margin="0,0,0,5">
                <ComboBoxItem Content="自动协商 (默认)"/>
                <ComboBoxItem Content="触屏模式 SDK (弹软键盘/仅支持英文)"/>
                <ComboBoxItem Content="物理模式 UHID (隐藏软键盘/支持中文)"/>
            </ComboBox>
            <TextBlock Text="* 提示：选 UHID 时软键盘会自动隐藏。请将电脑输入法切为【英文】，按 Shift+空格 (或 Ctrl+空格) 切换手机内置输入法打中文。" Foreground="#666666" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,20"/>

            <Rectangle Height="1" Fill="#333" Margin="0,0,0,10"/>
            <TextBlock Text="高级选项" Foreground="#AAAAAA" FontSize="14" Margin="0,0,0,10"/>
            <CheckBox x:Name="CheckScreenOff" Content="启动时自动息屏 (注意: 荣耀等严格管制的机型会闪退)" IsChecked="False" Foreground="White" FontSize="14" Margin="0,0,0,15"/>
            <CheckBox x:Name="CheckAudio" Content="同步传输手机系统声音到电脑" IsChecked="False" Foreground="White" FontSize="14" Margin="0,0,0,30"/>

            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="取 消" Background="#444444" Foreground="White" Height="40" FontSize="16" Cursor="Hand" BorderThickness="0" Click="Btn_CancelConfig_Click"/>
                <Button Grid.Column="2" Content="🚀 立即启动" Background="#A074E5" Foreground="White" Height="40" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Style="{DynamicResource PrimaryCyberButtonStyle}" Click="Btn_LaunchMirror_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>