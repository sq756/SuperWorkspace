                            <TextBlock Text="主屏接管" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center"/>
                            <TextBlock Text="Headless PC" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
