<UserControl x:Class="SuperWorkspace.TabletConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#CC000000">
    <Border Background="#252526" Width="400" Height="340" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
        <StackPanel>
            <TextBlock Text="🎨 专业数位板配置" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <TextBlock Text="压感曲线 (k值): " Foreground="#AAAAAA" FontSize="14"/>
                <TextBlock Text="{Binding ElementName=SliderPressureCurve, Path=Value, StringFormat={}{0:F2}}" Foreground="#A074E5" FontSize="14" FontWeight="Bold"/>
            </StackPanel>
            <Slider x:Name="SliderPressureCurve" Minimum="0.3" Maximum="3.0" Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="0,0,0,10"/>
            <TextBlock Text="* k &lt; 1 (向左): 笔触更灵敏，适合轻柔排线打草稿" Foreground="#888" FontSize="12" Margin="0,0,0,2"/>
            <TextBlock Text="* k &gt; 1 (向右): 笔触更沉稳，适合用力压感厚涂" Foreground="#888" FontSize="12" Margin="0,0,0,25"/>
            
            <CheckBox x:Name="CheckPalmReject" Content="开启极致防误触 (仅响应触控笔，屏蔽手指)" IsChecked="True" Foreground="White" FontSize="14" Margin="0,0,0,25"/>

            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="取 消" Background="#444444" Foreground="White" Height="40" FontSize="16" Cursor="Hand" BorderThickness="0" Click="Btn_CancelTabletConfig_Click"/>
                <Button Grid.Column="2" Content="🚀 唤醒专业压感画板" Background="#A074E5" Foreground="White" Height="40" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Style="{DynamicResource PrimaryCyberButtonStyle}" Click="Btn_LaunchTablet_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>