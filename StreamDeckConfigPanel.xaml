<UserControl x:Class="SuperWorkspace.StreamDeckConfigPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#CC000000">
    <Border Background="#252526" Width="400" Height="280" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
        <StackPanel>
            <TextBlock Text="🎛️ 自定义控制台配置" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            
            <TextBlock Text="此功能将使你的平板变成电脑的“外置智能宏键盘”。无需任何连线，点击屏幕瞬间操作电脑。" Foreground="#AAAAAA" FontSize="14" Margin="0,0,0,10" TextWrapping="Wrap"/>

            <TextBlock Text="* 提示：画面弹出后，在平板浏览器的右上角菜单中选择【添加到主屏幕】，即可获得类似原生 App 的全屏沉浸体验！并且可以通过平板上的【+】号自由添加快捷键和软件啦！" Foreground="#666666" FontSize="12" Margin="0,0,0,30" TextWrapping="Wrap"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="取 消" Background="#444444" Foreground="White" Height="40" FontSize="16" Cursor="Hand" BorderThickness="0" Click="Btn_CancelStreamDeckConfig_Click"/>
                <Button Grid.Column="2" Content="🚀 唤醒 Stream Deck 控制台" Background="#A074E5" Foreground="White" Height="40" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Style="{DynamicResource PrimaryCyberButtonStyle}" Click="Btn_LaunchStreamDeck_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>