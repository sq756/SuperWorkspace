                    <TextBlock Grid.Row="0" Text="📟 系统诊断黑匣子 (System Logs)" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <Border Grid.Row="1" Background="#0A0A0F" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="10" Margin="0,0,0,20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ListBox x:Name="BlackBoxFullList" Background="Transparent" BorderThickness="0" Foreground="#00CA72" FontFamily="Consolas" FontSize="12">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0,4"/>
                                        <Setter Property="Template">
                                            <Setter.Value><ControlTemplate TargetType="ListBoxItem"><ContentPresenter/></ControlTemplate></Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </ScrollViewer>
                    </Border>
                    <Button Grid.Row="2" Content="关 闭" Background="#444444" Foreground="White" Height="40" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_CloseBlackBox_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 🌟 定制版赛博朋克全局消息弹窗 -->
        <Grid x:Name="CyberMessageOverlay" Grid.RowSpan="2" Visibility="Collapsed" Background="#CC000000" Panel.ZIndex="3000">
            <Border Background="#252526" Width="400" MinHeight="200" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <StackPanel>
                    <TextBlock x:Name="CyberMessageTitle" Text="🔔 提示" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CyberMessageBody" Text="消息内容..." Foreground="#E0E0E0" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,30" LineHeight="22"/>
                    <Button Content="确 定" Background="#A074E5" Foreground="White" Height="40" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_CloseCyberMessage_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 🌟 无缝同步 (Zero-Sync) 全景雷达面板 -->
        <Grid x:Name="ZeroSyncOverlay" Grid.RowSpan="2" Visibility="Collapsed" Panel.ZIndex="3000" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,30,30">
            <Border Background="#EE111115" Width="380" Height="270" CornerRadius="12" Padding="20" BorderBrush="#33A074E5" BorderThickness="1">
                <Border.Effect><DropShadowEffect BlurRadius="20" Color="#A074E5" Opacity="0.3" ShadowDepth="0"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🌌 时空同步雷达 (Zero-Sync)" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Text="IEEE 1588 PTP 微秒级握手协议" Foreground="#00BFFF" FontSize="10" HorizontalAlignment="Center" Margin="0,22,0,10"/>
                    
                    <Border Grid.Row="1" Background="Transparent" CornerRadius="8" Padding="10" Margin="0,0,0,10" ClipToBounds="True">
                        <Grid>
                            <!-- 🌟 雷达物理同心圆 -->
                            <Ellipse Width="120" Height="120" Stroke="#33A074E5" StrokeThickness="2" StrokeDashArray="4 4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="60" Height="60" Stroke="#3300CA72" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="12" Height="12" Fill="#00BFFF" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse.Effect><DropShadowEffect Color="#00BFFF" BlurRadius="15" ShadowDepth="0"/></Ellipse.Effect>
                            </Ellipse>
                            
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,0,0">
                                <TextBlock Text="🖥️ 本地端" Foreground="#888" FontSize="10" Margin="0,0,0,3"/>
                                <TextBlock Text="Master Clock" Foreground="White" FontSize="12" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,0,0">
                                <TextBlock x:Name="Sync_Device" Text="等待设备连接..." Foreground="#888" FontSize="10" HorizontalAlignment="Right" Margin="0,0,0,3"/>
                                <TextBlock x:Name="Sync_Status" Text="休眠中" Foreground="Orange" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                                <TextBlock x:Name="Sync_Offset" Text="-- ms" Foreground="#A074E5" FontSize="18" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                                <TextBlock Text="晶振时空误差 (Offset)" Foreground="#A074E5" FontSize="10" HorizontalAlignment="Right"/>
                                <TextBlock x:Name="Sync_RTT" Text="-- ms" Foreground="#00CA72" FontSize="14" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                                <TextBlock Text="网络物理延迟 (RTT)" Foreground="#00CA72" FontSize="10" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <StackPanel Grid.Row="2" Margin="0,15,0,0">
                        <Button Content="🔮 开启边缘键鼠穿越 (无线 Flow)" Background="#1E1E1E" Foreground="#00BFFF" Height="30" FontSize="13" FontWeight="Bold" Cursor="Hand" BorderThickness="1" BorderBrush="#333" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_StartEdgeCrossing_Click" Margin="0,0,0,10"/>
                        <Button Content="隐 藏 雷 达" Background="#333" Foreground="#AAA" Height="26" FontSize="12" Cursor="Hand" BorderThickness="0" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_CloseZeroSync_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 🌟 插件市场面板 (Plugin Marketplace) -->
        <Grid x:Name="PluginMarketOverlay" Grid.RowSpan="2" Visibility="Collapsed" Background="#CC000000" Panel.ZIndex="3000">
            <Border Background="#252526" Width="600" Height="450" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🧩 扩展生态枢纽 (Plugin Hub)" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Text="想为 SuperWorkspace 开发新功能？👉 [查阅开发者文档与源码]" Foreground="#00BFFF" FontSize="13" Cursor="Hand" HorizontalAlignment="Center" Margin="0,35,0,20" MouseLeftButtonDown="Btn_OpenGitHub_Click"/>
                    
                    <Grid Grid.Row="1" Margin="0,10,0,20">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="15"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="8" Padding="15" BorderBrush="#333" BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="📦 本地已安装" Foreground="#A074E5" FontWeight="Bold"/>
                                    <TextBlock Text="📁 打开 Plugins 文件夹" Foreground="#00BFFF" FontSize="11" Margin="15,2,0,0" Cursor="Hand" MouseLeftButtonDown="Btn_OpenPluginsDir_Click"/>
                                </StackPanel>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="220">
                                    <StackPanel x:Name="PluginListContainer"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#1A1A1A" CornerRadius="8" Padding="15" BorderBrush="#333" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="🌐 在线精选 (GitHub 官方源)" Foreground="#00CA72" FontWeight="Bold" Margin="0,0,0,10"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="220">
                                    <StackPanel x:Name="OnlinePluginListContainer">
                                        <TextBlock x:Name="TxtOnlineLoading" Text="正在连接 GitHub 插件仓库..." Foreground="#666" FontSize="12" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Button Grid.Row="2" Content="关 闭" Background="#444" Foreground="White" Height="40" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_ClosePluginMarket_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 🌟 非阻塞式悬浮教程面板 (幽灵模式：背景透明不阻挡点击) -->
        <Grid x:Name="TutorialOverlay" Grid.RowSpan="2" Visibility="Collapsed" Panel.ZIndex="1500" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="30,0,0,90">
            <Border Background="#EE1A1A24" Width="360" MaxHeight="450" CornerRadius="12" Padding="20" BorderBrush="#A074E5" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Color="#A074E5" Opacity="0.3" ShadowDepth="0"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="📖" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="新手极客指南" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="🗝️ 1. 唤醒设备开发者灵魂" Foreground="#00BFFF" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="前往手机/平板「设置」> 连续点击「版本号」7次开启开发者模式 > 在「开发者选项」中开启「USB 调试」。" Foreground="#CCCCCC" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>
                            
                            <TextBlock Text="🔌 2. 首次有线连接与授权" Foreground="#00BFFF" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="用数据线连接电脑，务必在手机弹窗中勾选【始终允许这台计算机进行调试】并点击确定。" Foreground="#CCCCCC" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>

                            <TextBlock Text="🪄 3. 一键切换无线模式" Foreground="#00BFFF" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="确保设备与电脑在同一 Wi-Fi 下，点击右侧的【🪄 一键切换为无线模式】，出现成功提示后即可拔掉数据线！" Foreground="#CCCCCC" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>

                            <TextBlock Text="🚀 4. 享受九大魔法" Foreground="#00BFFF" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="现在，点击左侧的卡片，将平板化身为 120Hz 副屏、魔法触控板、或是专业的压感数位板吧！" Foreground="#CCCCCC" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,5"/>
                        </StackPanel>
                    </ScrollViewer>
                    <Button Grid.Row="2" Content="我知道了 (不影响操作，可随时关闭)" Background="#444" Foreground="White" Height="35" FontSize="13" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_CloseTutorial_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 🌟 交互式环境依赖与驱动自检报告面板 -->
        <Grid x:Name="DependencyOverlay" Grid.RowSpan="2" Visibility="Collapsed" Background="#CC000000" Panel.ZIndex="3500">
            <Border Background="#252526" Width="650" Height="550" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🔍 环境依赖与驱动体检报告" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <Border Grid.Row="1" Background="#15151A" CornerRadius="8" BorderBrush="#333" BorderThickness="1" Padding="20" Margin="0,0,0,20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="DependencyListContainer" />
                        </ScrollViewer>
                    </Border>
                    <Button Grid.Row="2" Content="关 闭" Background="#444444" Foreground="White" Height="40" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_CloseDependency_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 🌟 关于与设置面板 (About) -->
        <Grid x:Name="AboutOverlay" Grid.RowSpan="2" Visibility="Collapsed" Background="#CC000000" Panel.ZIndex="3000">
            <Border Background="#252526" Width="400" Height="500" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <StackPanel>
                    <TextBlock Text="⚙️ Super Workspace" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="v1.0.0" Foreground="#888" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <Button Content="📖 查看新手极客教程" Background="Transparent" Foreground="#00BFFF" Height="30" FontSize="13" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_ShowTutorial_Click"/>
                    </StackPanel>
                    
                    <TextBlock Text="显卡渲染引擎调度 (双显卡防卡死)" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ComboGpuPreference" SelectedIndex="2" FontSize="14" Height="35" Style="{StaticResource CyberComboBox}" Margin="0,0,0,20" SelectionChanged="ComboGpuPreference_SelectionChanged">
                        <ComboBoxItem Content="💻 自动分配 (由 Windows 决定)"/>
                        <ComboBoxItem Content="🍃 强制使用核显 (节能 / 单显卡)"/>
                        <ComboBoxItem Content="🎮 强制使用独显 (高性能 / 默认)"/>
                    </ComboBox>

                    <Button Content="🔍 环境依赖与驱动自检" Background="#1E1E1E" Foreground="#00CA72" Height="45" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="1" BorderBrush="#333" Margin="0,0,0,15" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_CheckDependencies_Click"/>
                    <Button x:Name="Btn_FixAdb" Content="🔌 强制重启通信引擎 (修复死活不弹授权)" Background="#333" Foreground="#D83B01" Height="45" FontSize="15" FontWeight="Bold" Cursor="Hand" BorderThickness="1" BorderBrush="#555" Margin="0,0,0,15" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_FixAdb_Click"/>
                    <Button Content="⭐ Star on GitHub" Background="#333" Foreground="White" Height="45" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="1" BorderBrush="#555" Margin="0,0,0,15" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_OpenGitHub_Click"/>
                    <Button Content="☕ 赞助开发者 (Sponsor)" Background="#A074E5" Foreground="White" Height="45" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Margin="0,0,0,30" Style="{StaticResource CyberActionButtonStyle}"/>
                    
                    <TextBlock Text="Copyright © 2026 d.Commander sq756 Studio. All rights reserved." Foreground="#555" FontSize="11" FontWeight="Light" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <Button Content="关 闭" Background="#444" Foreground="White" Height="40" FontSize="16" FontWeight="Bold" Cursor="Hand" BorderThickness="0" Style="{StaticResource CyberActionButtonStyle}" Click="Btn_CloseAbout_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 🌟 全局动态插拔组件容器 (取代原本冗长的千层饼代码) -->
        <ContentControl x:Name="OverlayContainer" Grid.RowSpan="2" Panel.ZIndex="5000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

    </Grid>
</Window>